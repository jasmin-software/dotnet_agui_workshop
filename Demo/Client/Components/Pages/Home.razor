@page "/"
@namespace Client.Components.Pages
@rendermode InteractiveServer

<div style="background-color: @(Color ?? "white")">
    <div class="chat-container">
        <div class="messages">
            @foreach (var message in Messages)
            {
                <div class="message-row @(message.IsUser ? "user" : "bot")">
                    <div class="bubble">

                        @if (message.IsApprovalRequest)
                        {
                            @((MarkupString)RenderMarkdown(message.Text))

                            <div class="approval-buttons">
                                <button class="approve-btn"
                                        @onclick="() => HandleApproval(true)">
                                    Approve ✔
                                </button>

                                <button class="deny-btn"
                                        @onclick="() => HandleApproval(false)">
                                    Deny ❌
                                </button>
                            </div>
                        }
                        else
                        {
                            @((MarkupString)RenderMarkdown(message.Text))
                        }
                    </div>
                </div>
            }

        </div>

        <div class="input-bar">
            <input @bind="CurrentMessage"
                @bind:event="oninput"
                @onkeydown="HandleKeyDown"
                placeholder="@(awaitingApproval 
                ? "Please approve or deny the request above..." 
                : "Type a message...")"
                class="chat-input"
                disabled="@awaitingApproval" />
            <input type="button" @onclick="SendMessage" value="Send" disabled="@awaitingApproval"/>
        </div>
    </div>
</div>
