@page "/calendar"
@using System.Globalization

<h3>February 2026 Calendar</h3> 
@* TODO, connect to backend to fetch Calandar data *@

<table class="calendar-table">
    <thead>
        <tr>
            @foreach (var dayName in DayNames)
            {
                <th>@dayName</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var week in Weeks)
        {
            <tr>
                @foreach (var day in week)
                {
                    if (day == 0)
                    {
                        <td class="empty"></td>
                    }
                    else
                    {
                        <td class="day">
                            <div class="day-number">@day</div>
                        </td>
                    }
                }
            </tr>
        }
    </tbody>
</table>

@code {
    private string[] DayNames = CultureInfo.CurrentCulture.DateTimeFormat.AbbreviatedDayNames;

    private List<List<int>> Weeks = new();

    protected override void OnInitialized()
    {
        int year = 2026;
        int month = 2; // February

        // 1st day of the month
        var firstDay = new DateTime(year, month, 1);
        int daysInMonth = DateTime.DaysInMonth(year, month);

        // Build weeks
        List<int> currentWeek = new List<int>();
        int dayOfWeekIndex = (int)firstDay.DayOfWeek;

        // Fill empty days at start
        for (int i = 0; i < dayOfWeekIndex; i++)
            currentWeek.Add(0);

        for (int day = 1; day <= daysInMonth; day++)
        {
            currentWeek.Add(day);
            if (currentWeek.Count == 7)
            {
                Weeks.Add(currentWeek);
                currentWeek = new List<int>();
            }
        }

        // Fill remaining empty days at the end
        if (currentWeek.Count > 0)
        {
            while (currentWeek.Count < 7)
                currentWeek.Add(0);

            Weeks.Add(currentWeek);
        }
    }
}
